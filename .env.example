# Copy to .env and fill in.

# Anthropic API key for the agent (Layer 2+).
ANTHROPIC_API_KEY=

# Postgres connection string the MCP tools use to query the DB.
# This is the default printed by `supabase start` for the local stack.
# NOTE: for real safety we will connect the query tool with a read-only role;
# this URL is the superuser/dev URL used for setup and admin.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
