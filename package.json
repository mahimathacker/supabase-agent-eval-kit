{
  "name": "supabase-agent-eval-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tests whether an AI agent can safely and correctly work with a Supabase project: inspect schema, write read-only SQL, explain tables, debug failed queries, and reason about RLS policies.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "mcp": "tsx src/tools/server.ts",
    "agent": "tsx src/agent/demo.ts",
    "eval": "tsx src/index.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@supabase/supabase-js": "^2.47.0",
    "commander": "^12.1.0",
    "dotenv": "^17.0.0",
    "pg": "^8.13.0",
    "pgsql-ast-parser": "^12.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
